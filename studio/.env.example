# Copier ce fichier en `.env` puis renseigner la valeur.
#
# URL du build hook Netlify (production). À créer dans Netlify :
#   Site settings → Build & deploy → Build hooks → Add build hook (branche : main)
# Le Studio l'utilise dans l'outil « Publier » pour redéclencher un build prod à la demande.
SANITY_STUDIO_NETLIFY_BUILD_HOOK=https://api.netlify.com/build_hooks/XXXXXXXXXXXXXXXX
